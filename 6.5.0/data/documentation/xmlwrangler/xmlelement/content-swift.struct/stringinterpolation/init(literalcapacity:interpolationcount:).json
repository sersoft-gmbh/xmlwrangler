          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "The approximate size of all literal segments",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "combined. This is meant to be passed to ",
                  "type" : "text"
                },
                {
                  "code" : "String.reserveCapacity(_:)",
                  "type" : "codeVoice"
                },
                {
                  "text" : ";",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "it may be slightly larger or smaller than the sum of the counts of each",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "literal segment.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "literalCapacity"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "The number of interpolations which will be",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "appended. Use this value to estimate how much additional capacity will",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "be needed for the interpolated segments.",
